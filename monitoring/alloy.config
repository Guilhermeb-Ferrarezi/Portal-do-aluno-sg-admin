logging {
  level  = "info"
  format = "logfmt"
}

discovery.docker "api" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "api_logs" {
  targets = discovery.docker.api.targets

  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
    regex         = "api"
    action        = "keep"
  }

  rule {
    target_label = "service"
    replacement  = "portal-do-aluno-api"
  }

  rule {
    source_labels = ["__meta_docker_container_name"]
    target_label  = "container"
  }
}

loki.source.docker "api" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.api_logs.output
  forward_to = [loki.process.api.receiver]
}

loki.process "api" {
  forward_to = [loki.write.local.receiver]

  stage.json {
    expressions = {
      level       = "level",
      service     = "service",
      env         = "env",
      message     = "message",
      route       = "route",
      status_code = "status_code",
      request_id  = "request_id",
      user_id     = "user_id",
    }
  }

  stage.labels {
    values = {
      level       = "level",
      service     = "service",
      env         = "env",
      route       = "route",
      status_code = "status_code",
    }
  }

  stage.static_labels {
    values = {
      stack = "portal-do-aluno",
    }
  }
}

loki.write "local" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}
